{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noEmitOnError": true,
    "rootDir": "benches/all_websites/ui",
    "outDir": "target/all_websites_ui"
  },
  "include": ["benches/all_websites/ui/**/*.ts"]
}
